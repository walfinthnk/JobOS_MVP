# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# JobOS MVP — 環境変数テンプレート
# このファイルをコピーして .env.local を作成すること
# .env.local は .gitignore で追跡除外済み（コミット禁止）
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Supabase ─────────────────────
# Supabase Dashboard > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth / Gmail API ──────
# Google Cloud Console > 認証情報 > OAuth 2.0 クライアント ID から取得
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Google Cloud Pub/Sub ──────────
# Google Cloud Console > Pub/Sub > トピック名を設定
# 例: projects/jobos-mvp/topics/gmail-notifications
GOOGLE_PUBSUB_TOPIC=

# ── トークン暗号化キー ────────────
# 32バイトのランダム文字列（下記コマンドで生成）
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ── アプリURL ─────────────────────
# ローカル開発時: http://localhost:3000
# 本番時: https://jobos-mvp.vercel.app（Vercel デプロイ後に更新）
NEXT_PUBLIC_APP_URL=http://localhost:3000
